//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// OB / FVG DETECTION (safe)
//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
bool isBullOB  = close[2] < open[2] and close[1] > open[1] and (close[1] - open[1]) > atrSL
bool isBearOB  = close[2] > open[2] and close[1] < open[1] and (open[1] - close[1]) > atrSL
float bullOBmid = (open[2] + close[2]) / 2.0
float bearOBmid = (open[1] + close[1]) / 2.0

if useOBFVG
    if isBullOB
        array.push(bullOBs, bullOBmid)
        if array.size(bullOBs) > 5
            array.shift(bullOBs)
    if isBearOB
        array.push(bearOBs, bearOBmid)
        if array.size(bearOBs) > 5
            array.shift(bearOBs)

bool  isBullFVG  = useOBFVG and (low > high[2])
bool  isBearFVG  = useOBFVG and (high < low[2])
float bullFVGmid = isBullFVG ? (low + high[2]) / 2.0 : na
float bearFVGmid = isBearFVG ? (high + low[2]) / 2.0 : na

if isBullFVG
    array.push(bullFVGs, bullFVGmid)
    if array.size(bullFVGs) > 5
        array.shift(bullFVGs)
if isBearFVG
    array.push(bearFVGs, bearFVGmid)
    if array.size(bearFVGs) > 5
        array.shift(bearFVGs)

// remove invalidated OB/FVG safely (reverse loops)
int n1 = array.size(bullOBs)
if n1 > 0
    for i = n1 - 1 to 0
        if low < array.get(bullOBs, i)
            array.remove(bullOBs, i)

int n2 = array.size(bearOBs)
if n2 > 0
    for i = n2 - 1 to 0
        if high > array.get(bearOBs, i)
            array.remove(bearOBs, i)

int n3 = array.size(bullFVGs)
if n3 > 0
    for i = n3 - 1 to 0
        if low < array.get(bullFVGs, i)
            array.remove(bullFVGs, i)

int n4 = array.size(bearFVGs)
if n4 > 0
    for i = n4 - 1 to 0
        if high > array.get(bearFVGs, i)
            array.remove(bearFVGs, i)

// ✅ FIX definitivo: función segura (no revienta si array size = 0)
f_nearOBFVG(float target, bool isBull, float entry) =>
    float best     = na
    float bestDist = 1e10

    if isBull
        int nOB = array.size(bearOBs)
        if nOB > 0
            for i = 0 to nOB - 1
                float lvl = array.get(bearOBs, i)
                if lvl > entry
                    float d = math.abs(lvl - target)
                    if d < bestDist
                        bestDist := d
                        best := lvl

        int nFVG = array.size(bearFVGs)
        if nFVG > 0
            for i = 0 to nFVG - 1
                float lvl = array.get(bearFVGs, i)
                if lvl > entry
                    float d = math.abs(lvl - target)
                    if d < bestDist
                        bestDist := d
                        best := lvl
    else
        int nOB = array.size(bullOBs)
        if nOB > 0
            for i = 0 to nOB - 1
                float lvl = array.get(bullOBs, i)
                if lvl < entry
                    float d = math.abs(lvl - target)
                    if d < bestDist
                        bestDist := d
                        best := lvl

        int nFVG = array.size(bullFVGs)
        if nFVG > 0
            for i = 0 to nFVG - 1
                float lvl = array.get(bullFVGs, i)
                if lvl < entry
                    float d = math.abs(lvl - target)
                    if d < bestDist
                        bestDist := d
                        best := lvl

    best

//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// RSI + DIVERGENCIA
//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
float rsiVal      = ta.rsi(close, rsiLen)
int   safeDivLB   = math.max(1, math.min(divLookback, bar_index))
float rsiPrevLo   = ta.lowest(rsiVal[1],  safeDivLB)
float rsiPrevHi   = ta.highest(rsiVal[1], safeDivLB)
float prcPrevLo   = ta.lowest(low,     safeDivLB)
float prcPrevHi   = ta.highest(high,   safeDivLB)

bool bullDiv = (low <= prcPrevLo) and (rsiVal > rsiPrevLo + 3) and (rsiVal < 45)
bool bearDiv = (high >= prcPrevHi) and (rsiVal < rsiPrevHi - 3) and (rsiVal > 55)

//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// SESIONES (UTC)
//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
int  utcH     = hour(time, "UTC")
bool isAsia   = (utcH >= 0) and (utcH < 8)
bool isLondon = (utcH >= 8) and (utcH < 13)
bool isNY     = (utcH >= 13) and (utcH < 21)
bool sessOK   = (not useSess) or (sessAsia and isAsia) or (sessLondon and isLondon) or (sessNY and isNY)

//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// FILTERS + RAW SIGNALS
//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
bool vol_ok = (not filterVol) or (volume > volSma20 * volMult)
bool atr_ok = (not filterAtr) or (atrSL > atrSma50 * atrMult)

bool raw_long  = show_long  and crossUpTL and vol_ok and atr_ok and barstate.isconfirmed
bool raw_short = show_short and crossDnTL and vol_ok and atr_ok and barstate.isconfirmed

bool htf_ok_long  = (not useHTF) or htfBull
bool htf_ok_short = (not useHTF) or (not htfBull)

//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// CONFLUENCE SCORE (0..5)
//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
int confLong = 0
if raw_long and htf_ok_long and sessOK
    confLong += 1
    if htfBull
        confLong += 1
    if useDivConf and bullDiv
        confLong += 1
    if volume > volSma20 * 1.2
        confLong += 1
    if isLondon or isNY
        confLong += 1

int confShort = 0
if raw_short and htf_ok_short and sessOK
    confShort += 1
    if not htfBull
        confShort += 1
    if useDivConf and bearDiv
        confShort += 1
    if volume > volSma20 * 1.2
        confShort += 1
    if isLondon or isNY
        confShort += 1

var int tradeConf = 0

//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// LIQUIDITY (PIVOTS) + SWEEP FILTER
//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
float ph = ta.pivothigh(high, pivLen, pivLen)
float pl = ta.pivotlow(low,  pivLen, pivLen)

// store pivots (with bar index of pivot center = bar_index - pivLen)
if not na(ph)
    array.push(pivHighs, ph)
    array.push(pivHighBar, bar_index - pivLen)

if not na(pl)
    array.push(pivLows, pl)
    array.push(pivLowBar, bar_index - pivLen)

// clean old pivots
int nh = array.size(pivHighs)
if nh > 0
    for i = nh - 1 to 0
        int b = array.get(pivHighBar, i)
        if bar_index - b > pivHoldBars
            array.remove(pivHighs, i)
            array.remove(pivHighBar, i)

int nl = array.size(pivLows)
if nl > 0
    for i = nl - 1 to 0
        int b = array.get(pivLowBar, i)
        if bar_index - b > pivHoldBars
            array.remove(pivLows, i)
            array.remove(pivLowBar, i)

// nearest pivot above (for longs danger) and below (for shorts danger)
f_nearestAbove(array<float> lvls, float price) =>
    float best = na
    float bestDist = 1e10
    int n = array.size(lvls)
    if n > 0
        for i = 0 to n - 1
            float v = array.get(lvls, i)
            if v >= price
                float d = v - price
                if d < bestDist
                    bestDist := d
                    best := v
    best

f_nearestBelow(array<float> lvls, float price) =>
    float best = na
    float bestDist = 1e10
    int n = array.size(lvls)
    if n > 0
        for i = 0 to n - 1
            float v = array.get(lvls, i)
            if v <= price
                float d = price - v
                if d < bestDist
                    bestDist := d
                    best := v
    best

float nearHigh = f_nearestAbove(pivHighs, close)
float nearLow  = f_nearestBelow(pivLows, close)

// sweep+reject detection (simple + robust):
f_recentBearSweep(float lvl, int lb) =>
    bool ok = false
    if not na(lvl)
        for k = 0 to lb - 1
            bool swept = high[k] > lvl and close[k] < lvl
            if swept
                ok := true
    ok

f_recentBullSweep(float lvl, int lb) =>
    bool ok = false
    if not na(lvl)
        for k = 0 to lb - 1
            bool swept = low[k] < lvl and close[k] > lvl
            if swept
                ok := true
    ok

bool bearSweepRecent = requireSweepReject ? f_recentBearSweep(nearHigh, sweepLookback) : false
bool bullSweepRecent = requireSweepReject ? f_recentBullSweep(nearLow,  sweepLookback) : false

// "break strength" 0..1
float volRel     = volSma20 > 0 ? (volume / volSma20) : 1.0
float momRel     = atrSL > 0 ? (math.abs(close - open) / atrSL) : 0.0
float strength01 = f_clamp01( (volRel - 1.0) * 0.6 + momRel * 0.4 )

// proximity in ATR
float distToHighATR = (not na(nearHigh) and atrSL > 0) ? (nearHigh - close) / atrSL : na
float distToLowATR  = (not na(nearLow)  and atrSL > 0) ? (close - nearLow)  / atrSL : na

bool nearOppLiqLong  = useLiqFilter and not na(distToHighATR) and distToHighATR >= 0 and distToHighATR <= proxATR
bool nearOppLiqShort = useLiqFilter and not na(distToLowATR)  and distToLowATR >= 0 and distToLowATR <= proxATR

bool blockLongByLiq  = useLiqFilter and nearOppLiqLong  and (strength01 < breakStrengthMin or bearSweepRecent)
bool blockShortByLiq = useLiqFilter and nearOppLiqShort and (strength01 < breakStrengthMin or bullSweepRecent)

//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// DETECCIÓN DE MERCADO LATERAL
//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
f_detect_ranging() =>
    // 1. Volatilidad baja: ATR actual < 75% del promedio
    float atrNorm = nz(atrSma50, atrSL) > 0 ? atrSL / nz(atrSma50, atrSL) : 1.0
    bool lowVol = atrNorm < 0.75

    // 2. Precio pegado al promedio gaussiano (< 0.5 ATR de distancia)
    float avgDist = atrSL > 0 ? math.abs(close - avg) / atrSL : 0.0
    bool nearAvg = avgDist < 0.5

    // 3. Muchos cruces del promedio en 15 barras = indecisión
    int crossCount = 0
    for i = 1 to 15
        bool crossed = (close[i] > avg[i] and close[i-1] < avg[i-1]) or
                       (close[i] < avg[i] and close[i-1] > avg[i-1])
        crossCount += crossed ? 1 : 0

    bool tooManyCrosses = crossCount >= 4

    // Lateral si: volatilidad baja + precio cerca del avg + muchos cruces
    lowVol and nearAvg and tooManyCrosses

bool isRanging = useRangeFilter ? f_detect_ranging() : false

//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// FINAL SIGNALS
//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
bool confOkLong  = useConfFilter ? (confLong >= minConf) : true
bool confOkShort = useConfFilter ? (confShort >= minConf) : true

bool long_signal  = raw_long  and htf_ok_long  and sessOK and (not blockLongByLiq) and confOkLong and (not isRanging)
bool short_signal = raw_short and htf_ok_short and sessOK and (not blockShortByLiq) and confOkShort and (not isRanging)

// Señales bloqueadas por confluencia (visual)
bool confBlockLong  = raw_long  and htf_ok_long  and sessOK and (not blockLongByLiq) and (not confOkLong)
bool confBlockShort = raw_short and htf_ok_short and sessOK and (not blockShortByLiq) and (not confOkShort)

bool retest_long  = show_retest and crossUpAVG and trend and barstate.isconfirmed
bool retest_short = show_retest and crossDnHighAVG and not trend and barstate.isconfirmed

//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// ADAPTIVE HTF TP
//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
f_adaptiveHTF(bool isBull, int tpNum) =>
    float result = na
    if tfSec <= 900
        result := tpNum == 1 ? (isBull ? h1h : h1l) :
                  tpNum == 2 ? (isBull ? h4h : h4l) :
                  tpNum == 3 ? (isBull ? pdh : pdl) :
                  (isBull ? pwh : pwl)
    else if tfSec <= 3600
        result := tpNum == 1 ? (isBull ? h4h : h4l) :
                  tpNum == 2 ? (isBull ? pdh : pdl) :
                  (isBull ? pwh : pwl)
    else
        result := tpNum == 1 ? (isBull ? pdh : pdl) : (isBull ? pwh : pwl)
    result

f_snap(float base, float rTarget, bool isBull, float htfLvl, float obfvgLvl) =>
    float snap = rTarget
    float tol  = math.abs(rTarget - base) * (snapPct / 100.0)
    float best = tol

    if not na(obfvgLvl)
        bool valid1 = isBull ? (obfvgLvl > base) : (obfvgLvl < base)
        float d1 = math.abs(obfvgLvl - rTarget)
        if valid1 and d1 < best
            best := d1
            snap := obfvgLvl

    if not na(htfLvl)
        bool valid2 = isBull ? (htfLvl > base) : (htfLvl < base)
        float d2 = math.abs(htfLvl - rTarget)
        if valid2 and d2 < best
            best := d2
            snap := htfLvl

    snap

