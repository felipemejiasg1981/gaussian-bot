bool strongLong  = show_strong and long_signal and (score < 0.25)
bool strongShort = show_strong and short_signal and (score > 0.75)

if show_long and long_signal and (not strongLong)
    f_sigLabel(bar_index, trend_line, score > 0.5 ? "▲+" : "▲", up, chart.bg_color, "upper_right", score > 0.5 ? "small" : "tiny")

if show_short and short_signal and (not strongShort)
    f_sigLabel(bar_index, trend_line, score < 0.5 ? "▼+" : "▼", dn, chart.fg_color, "lower_right", score < 0.5 ? "small" : "tiny")

if strongLong
    f_sigLabel(bar_index, trend_line, "▲+", #58A6FF, color.white, "upper_right", "normal")

if strongShort
    f_sigLabel(bar_index, trend_line, "▼+", #58A6FF, color.white, "lower_right", "normal")

if show_retest and retest_long and (not retest2_long)
    f_sigLabel(bar_index[1], low[1], "▲", color(na), chart.fg_color, "up", "small")

if show_retest and retest_short and (not retest2_short)
    f_sigLabel(bar_index[1], high[1], "▼", color(na), chart.fg_color, "down", "small")

if show_entry2 and retest2_long
    f_sigLabel(bar_index, low, "E2", #FF6F00, chart.bg_color, "up", "small")

if show_entry2 and retest2_short
    f_sigLabel(bar_index, high, "E2", #FF6F00, chart.bg_color, "down", "small")

// marcadores de bloqueo por liquidez contraria
if raw_long and (not long_signal) and blockLongByLiq
    f_sigLabel(bar_index, trend_line, "▲X LIQ", color.new(color.red, 65), color.white, "upper_right", "tiny")

if raw_short and (not short_signal) and blockShortByLiq
    f_sigLabel(bar_index, trend_line, "▼X LIQ", color.new(color.red, 65), color.white, "lower_right", "tiny")

