    f_sigLabel(bar_index, low, "⊘ CONF", color.new(#FF9800, 50), color.white, "up", "tiny")

if confBlockShort
    f_sigLabel(bar_index, high, "⊘ CONF", color.new(#FF9800, 50), color.white, "down", "tiny")

