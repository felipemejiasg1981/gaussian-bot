        label.set_text(tl.lb_sl, f_slLbl("SL", trailSL, entryPrice))

    if not na(tl.ln_entry)
        line.set_x2(tl.ln_entry, x2)
        if (not tp1_hit) and (not na(tl.lb_entry))
            label.set_x(tl.lb_entry, x2)

    if not na(tl.ln_tp1)
        line.set_x2(tl.ln_tp1, x2)
        if not na(tl.lb_tp1)
            label.set_x(tl.lb_tp1, x2)

    if not na(tl.ln_tp2)
        line.set_x2(tl.ln_tp2, x2)
        if not na(tl.lb_tp2)
            label.set_x(tl.lb_tp2, x2)

    if not na(tl.ln_tp3)
        line.set_x2(tl.ln_tp3, x2)
        if not na(tl.lb_tp3)
            label.set_x(tl.lb_tp3, x2)

    if not na(tl.ln_tp4)
        line.set_x2(tl.ln_tp4, x2)
        if not na(tl.lb_tp4)
            label.set_x(tl.lb_tp4, x2)

