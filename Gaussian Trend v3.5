// GAUSSIAN VISUALS
//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
plot(avg, color=clr, linewidth=1)
bool _tlChange = not na(trend_line) and (na(trend_line[1]) or trend_line != trend_line[1])
float _tlClean = useDashed ? (_tlChange ? trend_line : na) : trend_line
plot(_tlClean, color=close > trend_line ? up : dn, linewidth=2, style=useDashed ? plot.style_circles : plot.style_linebr)

