bool _emaRev = ta.crossover(ta.ema(close,50), ta.ema(close,200)) or ta.crossunder(ta.ema(close,50), ta.ema(close,200))

[m5Bull,  m5Rev]  = request.security(syminfo.tickerid, "5",
     [close > ta.ema(close, 200), _emaRev],
     lookahead=barmerge.lookahead_off)

[m15Bull, m15Rev] = request.security(syminfo.tickerid, "15",
     [close > ta.ema(close, 200), _emaRev],
     lookahead=barmerge.lookahead_off)

[h1Bull,  h1Rev]  = request.security(syminfo.tickerid, "60",
     [close > ta.ema(close, 200), _emaRev],
     lookahead=barmerge.lookahead_off)

[h4Bull,  h4Rev]  = request.security(syminfo.tickerid, "240",
     [close > ta.ema(close, 200), _emaRev],
     lookahead=barmerge.lookahead_off)

[dBull,   dRev]   = request.security(syminfo.tickerid, "D",
