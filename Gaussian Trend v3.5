// GAUSSIAN FILTER + MULTI TREND (cached weights)
//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

// Pre-compute gaussian weights for all 21 steps (only once)
var array<float> gaussCache = array.new_float(0)
var array<int>   gaussIndex = array.new_int(21, 0)

if barstate.isfirst
    float sigma = 10.0
    int currentOffset = 0
    for step = 0 to 20
        int length = len + step
        array.set(gaussIndex, step, currentOffset)
        float total = 0.0
        // First pass: Calculate raw weights
        for i = 0 to length - 1
            float wt = math.exp(-0.5 * math.pow((i - length / 2.0) / sigma, 2.0)) / math.sqrt(sigma * 2.0 * math.pi)
            array.push(gaussCache, wt)
            total += wt
        // Second pass: Normalize weights in place
        for i = 0 to length - 1
            int idx = currentOffset + i
            array.set(gaussCache, idx, array.get(gaussCache, idx) / total)
        currentOffset += length

// Fast convolution using cached weights (no exp/pow)
gaussian_filter_fast(series float src, int step) =>
    int offset = array.get(gaussIndex, step)
    int n = len + step
    float s = 0.0
    for i = 0 to n - 1
        s += src[i] * array.get(gaussCache, offset + i)
    s

multi_trend(series float src, int period) =>
    array<float> g = array.new_float(0)
    float vol = ta.sma(high - low, 100)

    for step = 0 to 20
        array.push(g, gaussian_filter_fast(src, step))

    float sc = 0.0
    float first = array.size(g) > 0 ? array.get(g, 0) : src
    int gs = array.size(g)
    for i = 0 to gs - 1
        if array.get(g, i) > first
            sc += 0.05

    color clr = sc > 0.5 ? color.from_gradient(sc, 0.5, 1.0, na, dn) : color.from_gradient(sc, 0.0, 0.5, up, na)

    float val = switch mode
        "AVG"    => array.avg(g)
        "MEDIAN" => array.median(g)
        "MODE"   => array.mode(g)

    float lb = val - vol * distance
    float ub = val + vol * distance

    bool cross_up = ta.crossover(src, ub)
    bool cross_dn = ta.crossunder(src, lb)
    bool tr = nz(ta.valuewhen(cross_up or cross_dn, cross_up, 0), false)

    float tlv = tr ? lb : ub
    [sc, val, clr, tlv, tr, vol, lb, ub]

