// LONG ENTRY
//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
if long_signal
    if trade_open
        float r_risk = math.abs(entryPrice - slP)
        float exit_p = close // Reversed by opposite signal
        float _r = r_risk > 0 ? (bull ? ((exit_p - entryPrice) / r_risk) : ((entryPrice - exit_p) / r_risk)) : 0.0
        stat_total += 1
        if _r > 0
            stat_wins += 1
            stat_winR += _r
            stat_streak += 1
            stat_bestStrk := math.max(stat_bestStrk, stat_streak)
            stat_tp4c += tp4_hit ? 1 : 0
            stat_tp3c += (not tp4_hit and tp3_hit) ? 1 : 0
            stat_tp2c += (not tp3_hit and tp2_hit) ? 1 : 0
            stat_tp1c += (not tp2_hit and tp1_hit) ? 1 : 0
