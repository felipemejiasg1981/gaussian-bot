f_nearOBFVG(float target, bool isBull, float entry) =>
    float best     = na
    float bestDist = 1e10
    if isBull
        int nOB = array.size(bearOBs)
        if nOB > 0
            for i = 0 to nOB - 1
                float lvl = array.get(bearOBs, i)
                if lvl > entry
                    float d = math.abs(lvl - target)
                    if d < bestDist
                        bestDist := d
                        best := lvl
        int nFVG = array.size(bearFVGs)
        if nFVG > 0
            for i = 0 to nFVG - 1
                float lvl = array.get(bearFVGs, i)
                if lvl > entry
                    float d = math.abs(lvl - target)
                    if d < bestDist
                        bestDist := d
                        best := lvl
    else
        int nOB = array.size(bullOBs)
        if nOB > 0
            for i = 0 to nOB - 1
                float lvl = array.get(bullOBs, i)
                if lvl < entry
                    float d = math.abs(lvl - target)
                    if d < bestDist
                        bestDist := d
                        best := lvl
        int nFVG = array.size(bullFVGs)
        if nFVG > 0
            for i = 0 to nFVG - 1
                float lvl = array.get(bullFVGs, i)
                if lvl < entry
                    float d = math.abs(lvl - target)
                    if d < bestDist
                        bestDist := d
                        best := lvl
    best

