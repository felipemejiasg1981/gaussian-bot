    float R      = ent - sl
    float be     = ent * (1.0 + feePct)
    float rtp1 = ent + R * tp1R
    float rtp2 = ent + R * tp2R
    float rtp3 = ent + R * tp3R
    float htf1 = f_adaptiveHTF(true, 1)
    float htf2 = f_adaptiveHTF(true, 2)
    float htf3 = f_adaptiveHTF(true, 3)
    float ob1 = useLiq ? f_nearOBFVG(rtp1, true, ent) : na
    float ob2 = useLiq ? f_nearOBFVG(rtp2, true, ent) : na
    float ob3 = useLiq ? f_nearOBFVG(rtp3, true, ent) : na
