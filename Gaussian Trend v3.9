float rsiPrevHi = ta.highest(rsiVal[1], divLookback)
float prcPrevLo = ta.lowest(low,     divLookback)
float prcPrevHi = ta.highest(high,   divLookback)
bool bullDiv = (low <= prcPrevLo) and (rsiVal > rsiPrevLo + 3) and (rsiVal < 45)
bool bearDiv = (high >= prcPrevHi) and (rsiVal < rsiPrevHi - 3) and (rsiVal > 55)

