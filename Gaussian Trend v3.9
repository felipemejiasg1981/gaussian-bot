        line.set_y1(tl.ln_sl, trailSL)
        line.set_y2(tl.ln_sl, trailSL)
    if not na(tl.lb_sl)
        label.set_x(tl.lb_sl, x2)
        label.set_y(tl.lb_sl, trailSL)
