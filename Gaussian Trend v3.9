// ── HELPERS ──
f_rr(float price, float entry, float sl) =>
    float risk = math.abs(entry - sl)
    float rew  = math.abs(price - entry)
    risk > 0 ? str.tostring(rew / risk, "#.##") + "R" : "-"

f_lbl(string nm, float price, float entry, float sl, float pctClose) =>
    nm + "  " + str.tostring(price, "#.####") + "  [" + f_rr(price, entry, sl) + "]  <- " + str.tostring(pctClose, "#") + "%"

f_slLbl(string nm, float price, float entry) =>
    float pct = (price - entry) / entry * 100.0
    nm + "  " + str.tostring(price, "#.####") + "  (" + (pct >= 0 ? "+" : "") + str.tostring(pct, "#.##") + "%)"

f_safeLineDelete(line ln) =>
    if not na(ln)
        line.delete(ln)
f_safeLabelDelete(label lb) =>
    if not na(lb)
        label.delete(lb)
f_safeFillDelete(linefill lf) =>
    if not na(lf)
        linefill.delete(lf)

f_clear() =>
    f_safeLineDelete(tl.ln_entry)
    f_safeLineDelete(tl.ln_sl)
    f_safeLineDelete(tl.ln_be)
    f_safeLineDelete(tl.ln_tp1)
    f_safeLineDelete(tl.ln_tp2)
    f_safeLineDelete(tl.ln_tp3)
    f_safeLabelDelete(tl.lb_entry)
    f_safeLabelDelete(tl.lb_sl)
    f_safeLabelDelete(tl.lb_be)
    f_safeLabelDelete(tl.lb_tp1)
    f_safeLabelDelete(tl.lb_tp2)
    f_safeLabelDelete(tl.lb_tp3)
    f_safeFillDelete(tl.lf_risk)
    f_safeFillDelete(tl.lf_zone)
    f_safeFillDelete(tl.lf_ext)
    int n = array.size(sigLabels)
    if n > 0
        for i = 0 to n - 1
            label l = array.get(sigLabels, i)
            if not na(l)
                label.delete(l)
        array.clear(sigLabels)

f_sigLabel(int x, float y, string txt, color bgCol, color txtCol, string stl, string sz) =>
    label lbl = na
    bool szNormal = (sz == "normal")
    bool szSmall  = (sz == "small")
    if stl == "down"
        if szNormal
            lbl := label.new(x, y, txt, color=bgCol, textcolor=txtCol, size=size.normal, style=label.style_label_down)
        else if szSmall
            lbl := label.new(x, y, txt, color=bgCol, textcolor=txtCol, size=size.small, style=label.style_label_down)
        else
            lbl := label.new(x, y, txt, color=bgCol, textcolor=txtCol, size=size.tiny, style=label.style_label_down)
    else if stl == "upper_right"
        if szNormal
            lbl := label.new(x, y, txt, color=bgCol, textcolor=txtCol, size=size.normal, style=label.style_label_upper_right)
        else if szSmall
            lbl := label.new(x, y, txt, color=bgCol, textcolor=txtCol, size=size.small, style=label.style_label_upper_right)
        else
            lbl := label.new(x, y, txt, color=bgCol, textcolor=txtCol, size=size.tiny, style=label.style_label_upper_right)
    else if stl == "lower_right"
        if szNormal
            lbl := label.new(x, y, txt, color=bgCol, textcolor=txtCol, size=size.normal, style=label.style_label_lower_right)
        else if szSmall
            lbl := label.new(x, y, txt, color=bgCol, textcolor=txtCol, size=size.small, style=label.style_label_lower_right)
        else
            lbl := label.new(x, y, txt, color=bgCol, textcolor=txtCol, size=size.tiny, style=label.style_label_lower_right)
    else
        if szNormal
            lbl := label.new(x, y, txt, color=bgCol, textcolor=txtCol, size=size.normal, style=label.style_label_up)
        else if szSmall
            lbl := label.new(x, y, txt, color=bgCol, textcolor=txtCol, size=size.small, style=label.style_label_up)
        else
            lbl := label.new(x, y, txt, color=bgCol, textcolor=txtCol, size=size.tiny, style=label.style_label_up)
    array.push(sigLabels, lbl)
    lbl

f_clamp01(float x) => math.max(0.0, math.min(1.0, x))

