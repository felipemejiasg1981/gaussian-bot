    float _tp2 = useLiq ? f_snap(ent, rtp2, true, htf2, ob2) : rtp2
    float _tp3 = useLiq ? f_snap(ent, rtp3, true, htf3, ob3) : rtp3
    _tp2 := _tp2 <= _tp1 ? rtp2 : _tp2
    _tp3 := _tp3 <= _tp2 ? rtp3 : _tp3
