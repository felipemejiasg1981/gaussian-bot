// FIX-1: Cálculo R ponderado real
f_calcRealR(bool isBull, float entry, float initRisk, bool h1, bool h2, bool h3, float p1, float p2, float p3, float exitPx) =>
    float pnl = 0.0
    float rem = 100.0
    if h1
        pnl += (pct_tp1 / 100.0) * (isBull ? (p1 - entry) : (entry - p1))
        rem -= pct_tp1
    if h2
        pnl += (pct_tp2 / 100.0) * (isBull ? (p2 - entry) : (entry - p2))
        rem -= pct_tp2
    if h3
        pnl += (pct_tp3 / 100.0) * (isBull ? (p3 - entry) : (entry - p3))
        rem -= pct_tp3
    pnl += (rem / 100.0) * (isBull ? (exitPx - entry) : (entry - exitPx))
    initRisk > 0 ? pnl / initRisk : 0.0

// ── GAUSSIAN FILTER (FIX-5: sigma dinámico) ──
gaussian_filter(series float src, int length, float sigma) =>
    array<float> w = array.new_float(length, 0.0)
    float total = 0.0
    for i = 0 to length - 1
        float wt = math.exp(-0.5 * math.pow((i - length / 2.0) / sigma, 2.0)) / math.sqrt(sigma * 2.0 * math.pi)
        array.set(w, i, wt)
        total += wt
    for i = 0 to length - 1
        array.set(w, i, array.get(w, i) / total)
    float s = 0.0
    for i = 0 to length - 1
        s += src[i] * array.get(w, i)
    s

multi_trend(series float src, int period) =>
    array<float> g = array.new_float(0)
    float vol = ta.sma(high - low, 100)
    var float lb = 0.0
    var float ub = 0.0
    var bool  tr = false
    float dynSigma = math.max(3.0, period * 0.3)  // FIX-5
    for step = 0 to 20
        array.push(g, gaussian_filter(src, period + step, dynSigma))
    float sc = 0.0
    float first = array.size(g) > 0 ? array.get(g, 0) : src
    int gs = array.size(g)
    for i = 0 to gs - 1
        if array.get(g, i) > first
            sc += 0.05
    color clr = sc > 0.5 ? color.from_gradient(sc, 0.5, 1.0, na, dn) : color.from_gradient(sc, 0.0, 0.5, up, na)
    float val = switch mode
        "AVG"    => array.avg(g)
        "MEDIAN" => array.median(g)
        "MODE"   => array.mode(g)
    lb := val - vol * distance
    ub := val + vol * distance
    if ta.crossover(src, ub)
        tr := true
    if ta.crossunder(src, lb)
        tr := false
    float tlv = tr ? lb : ub
    [sc, val, clr, tlv, tr, vol, lb, ub]

