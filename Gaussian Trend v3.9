bool e2_short_lvl2 = avgBroken and high >= entryBand and close < entryBand
bool retest2_long  = show_entry2 and active and bull and (not entryFull) and (not long_signal) and (not na(entryBand)) and (e2_long_lvl1 or e2_long_lvl2) and barstate.isconfirmed
bool retest2_short = show_entry2 and active and (not bull) and (not entryFull) and (not short_signal) and (not na(entryBand)) and (e2_short_lvl1 or e2_short_lvl2) and barstate.isconfirmed
if retest2_long
    entryFull := true
if retest2_short
    entryFull := true
bool reentry_long  = showReentry and active and bull and crossUpAVG and close > trailSL and (not long_signal) and (not retest2_long) and barstate.isconfirmed
bool reentry_short = showReentry and active and (not bull) and crossDnAVG and close < trailSL and (not short_signal) and (not retest2_short) and barstate.isconfirmed
if reentry_long
    f_sigLabel(bar_index, low - atrStable * 0.3, "R", color.new(#00BCD4, 50), color.white, "up", "small")
if reentry_short
    f_sigLabel(bar_index, high + atrStable * 0.3, "R", color.new(#FF9800, 50), color.white, "down", "small")

