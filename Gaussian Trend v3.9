// ── FROST AI (FIX-3: alineado con tendencia Gaussiana) ──
f_smoothrng(x, t, m) =>
    wper = t * 2 - 1
    avrng = ta.ema(math.abs(x - nz(x[1])), t)
    ta.ema(avrng, wper) * m
f_rngfilt(x, r) =>
    var float rngfilt = x
    rngfilt := x > rngfilt[1] ? (x - r < rngfilt[1] ? rngfilt[1] : x - r) : (x + r > rngfilt[1] ? rngfilt[1] : x + r)
    rngfilt
float smrng1 = f_smoothrng(close, 27, 1.5)
float smrng2 = f_smoothrng(close, 55, f_sens)
float smrng  = (smrng1 + smrng2) / 2
float filt   = f_rngfilt(close, smrng)
var float upC = 0.0
upC := filt > filt[1] ? nz(upC[1]) + 1 : (filt < filt[1] ? 0 : nz(upC[1]))
var float dnC = 0.0
dnC := filt < filt[1] ? nz(dnC[1]) + 1 : (filt > filt[1] ? 0 : nz(dnC[1]))
bool frost_bullCond = (close > filt and close > close[1] and upC > 0) or (close > filt and close < close[1] and upC > 0)
bool frost_bearCond = (close < filt and close < close[1] and dnC > 0) or (close < filt and close > close[1] and dnC > 0)
var int lastCond = 0
lastCond := frost_bullCond ? 1 : (frost_bearCond ? -1 : nz(lastCond[1]))
bool frost_bull = frost_bullCond and lastCond[1] == -1
bool frost_bear = frost_bearCond and lastCond[1] == 1
float f_off = (ta.highest(300) - ta.lowest(300)) * 6 / 100
bool show_frost_bull = use_frost and frost_bull and not crossUpTL
bool show_frost_bear = use_frost and frost_bear and not crossDnTL
plotshape(show_frost_bull ? low - f_off : na, 'Frost Bullish', shape.labelup, location.absolute, c_frostB, 0, '▲', color.white, size=size.small)
plotshape(show_frost_bear ? high + f_off : na, 'Frost Bearish', shape.labeldown, location.absolute, c_frostS, 0, '▼', color.white, size=size.small)


