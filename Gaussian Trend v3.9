f_nearestAbove(array<float> lvls, float price) =>
    float best = na
    float bestDist = 1e10
    int n = array.size(lvls)
    if n > 0
        for i = 0 to n - 1
            float v = array.get(lvls, i)
            if v >= price
                float d = v - price
                if d < bestDist
                    bestDist := d
                    best := v
    best

f_nearestBelow(array<float> lvls, float price) =>
    float best = na
    float bestDist = 1e10
    int n = array.size(lvls)
    if n > 0
        for i = 0 to n - 1
            float v = array.get(lvls, i)
            if v <= price
                float d = price - v
                if d < bestDist
                    bestDist := d
                    best := v
    best

float nearHigh = f_nearestAbove(pivHighs, close)
float nearLow  = f_nearestBelow(pivLows, close)

f_recentBearSweep(float lvl, int lb) =>
    bool ok = false
    if not na(lvl)
        for k = 0 to lb - 1
            bool swept = high[k] > lvl and close[k] < lvl
            if swept
                ok := true
    ok
f_recentBullSweep(float lvl, int lb) =>
    bool ok = false
    if not na(lvl)
        for k = 0 to lb - 1
            bool swept = low[k] < lvl and close[k] > lvl
            if swept
                ok := true
    ok

